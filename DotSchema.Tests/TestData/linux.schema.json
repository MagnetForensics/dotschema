{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Config",
  "type": "object",
  "properties": {
    "shared_setting": {
      "type": "string"
    },
    "linux_only": {
      "type": "string"
    },
    "process_config": {
      "$ref": "#/definitions/ProcessConfig"
    }
  },
  "definitions": {
    "SharedType": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "value": { "type": "integer" }
      }
    },
    "ProcessConfig": {
      "type": "object",
      "properties": {
        "exe_path": { "type": "string" },
        "systemd_unit": { "type": "string" }
      }
    },
    "LinuxOnlyType": {
      "type": "object",
      "properties": {
        "systemd": { "type": "string" }
      }
    }
  }
}

